{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "scrutiny values",
  "description": "Configurable Helm values for the scrutiny chart.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "description": "Container image settings for the main application container.",
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository used for the main application container.",
          "default": "ghcr.io/analogj/scrutiny"
        },
        "tag": {
          "type": "string",
          "description": "Container image tag to deploy. Pin this to a concrete version for repeatable installs and predictable upgrades.",
          "default": "v0.9.2-web"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Kubernetes image pull policy for the container.",
          "default": "IfNotPresent"
        }
      }
    },
    "influxdb": {
      "type": "object",
      "description": "InfluxDB settings used by Scrutiny for metrics storage.",
      "additionalProperties": true,
      "properties": {
        "image": {
          "type": "object",
          "description": "Image setting for image.",
          "additionalProperties": true,
          "properties": {
            "repository": {
              "type": "string",
              "description": "Container image repository.",
              "default": "influxdb"
            },
            "tag": {
              "type": "string",
              "description": "Container image tag.",
              "default": "2.8"
            },
            "pullPolicy": {
              "type": "string",
              "description": "Kubernetes image pull policy.",
              "default": "IfNotPresent"
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "CPU and memory requests and limits.",
          "additionalProperties": true,
          "properties": {}
        }
      }
    },
    "initContainer": {
      "type": "object",
      "description": "Initialization container settings used before the main application starts.",
      "additionalProperties": true,
      "properties": {
        "image": {
          "type": "object",
          "description": "Image setting for image.",
          "additionalProperties": true,
          "properties": {
            "repository": {
              "type": "string",
              "description": "Container image repository.",
              "default": "busybox"
            },
            "tag": {
              "type": "string",
              "description": "Container image tag.",
              "default": "1.36"
            },
            "pullPolicy": {
              "type": "string",
              "description": "Kubernetes image pull policy.",
              "default": "IfNotPresent"
            }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Kubernetes Service configuration for exposing the application inside the cluster.",
      "additionalProperties": true,
      "properties": {
        "port": {
          "type": "integer",
          "description": "Service port exposed inside the cluster.",
          "default": 8080
        }
      }
    },
    "scrutiny": {
      "type": "object",
      "description": "Scrutiny application configuration.",
      "additionalProperties": true,
      "properties": {
        "web": {
          "type": "object",
          "description": "Configuration block for web.",
          "additionalProperties": true,
          "properties": {
            "basepath": {
              "type": "string",
              "description": "Optional URL base path for serving the Scrutiny web UI behind a reverse proxy path.",
              "default": ""
            },
            "database": {
              "type": "object",
              "description": "Database name.",
              "additionalProperties": true,
              "properties": {
                "location": {
                  "type": "string",
                  "description": "Filesystem path to the Scrutiny SQLite database file.",
                  "default": "/opt/scrutiny/config/scrutiny.db"
                }
              }
            },
            "influxdb": {
              "type": "object",
              "description": "Configuration block for influxdb.",
              "additionalProperties": true,
              "properties": {
                "scheme": {
                  "type": "string",
                  "description": "HTTP scheme used by Scrutiny when connecting to InfluxDB.",
                  "default": "http"
                },
                "host": {
                  "type": "string",
                  "description": "Hostname matched by this rule.",
                  "default": "127.0.0.1"
                },
                "port": {
                  "type": "integer",
                  "description": "Port number or named port used by this setting.",
                  "default": 8086
                },
                "retentionPolicy": {
                  "type": "boolean",
                  "description": "Whether Scrutiny should manage or use an InfluxDB retention policy for collected metrics.",
                  "default": true
                }
              }
            }
          }
        },
        "log": {
          "type": "object",
          "description": "Configuration block for log.",
          "additionalProperties": true,
          "properties": {
            "file": {
              "type": "string",
              "description": "Optional log file path. Leave empty to log to standard output.",
              "default": ""
            },
            "level": {
              "type": "string",
              "description": "Scrutiny log level.",
              "default": "INFO"
            }
          }
        },
        "notify": {
          "type": "object",
          "description": "Configuration block for notify.",
          "additionalProperties": true,
          "properties": {
            "urls": {
              "type": "array",
              "description": "List of urls entries.",
              "default": [],
              "items": {}
            }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistent storage configuration used by the chart.",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to create or mount persistent storage for this component.",
          "default": true
        },
        "accessMode": {
          "type": "string",
          "description": "PersistentVolumeClaim access mode requested for Scrutiny storage.",
          "default": "ReadWriteOnce"
        },
        "storageClassName": {
          "type": "string",
          "description": "StorageClass name for the generated PVC. Leave empty to use the cluster default.",
          "default": ""
        },
        "scrutiny": {
          "type": "object",
          "description": "Configuration block for scrutiny.",
          "additionalProperties": true,
          "properties": {
            "size": {
              "type": "string",
              "description": "PersistentVolumeClaim storage request size.",
              "default": "1Gi"
            }
          }
        },
        "influxdb": {
          "type": "object",
          "description": "Configuration block for influxdb.",
          "additionalProperties": true,
          "properties": {
            "size": {
              "type": "string",
              "description": "PersistentVolumeClaim storage request size.",
              "default": "10Gi"
            }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "description": "Kubernetes Ingress configuration for exposing the application through an ingress controller.",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to create an Ingress resource.",
          "default": false
        },
        "className": {
          "type": "string",
          "description": "IngressClass name used by the target ingress controller.",
          "default": "traefik"
        },
        "annotations": {
          "type": "object",
          "description": "Additional annotations applied to the Ingress resource.",
          "additionalProperties": true,
          "properties": {}
        },
        "host": {
          "type": "string",
          "description": "Hostname matched by this rule.",
          "default": "scrutiny.local"
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "description": "Gateway API HTTPRoute configuration for exposing the application through a Gateway.",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to create a Gateway API HTTPRoute resource.",
          "default": false
        },
        "annotations": {
          "type": "object",
          "description": "Additional annotations applied to the HTTPRoute resource.",
          "additionalProperties": true,
          "properties": {}
        },
        "parentRefs": {
          "type": "array",
          "description": "Gateway parentRefs that attach this HTTPRoute to one or more Gateways.",
          "default": [
            {
              "name": "traefik",
              "namespace": "kube-system"
            }
          ],
          "items": {
            "type": "object",
            "description": "Gateway API parent reference that attaches the HTTPRoute to a Gateway or listener.",
            "additionalProperties": true,
            "properties": {
              "name": {
                "type": "string",
                "description": "Name assigned to this Kubernetes object, port, reference, or setting.",
                "default": "traefik"
              },
              "namespace": {
                "type": "string",
                "description": "Optional Kubernetes namespace for the referenced object.",
                "default": "kube-system"
              }
            }
          }
        },
        "hostnames": {
          "type": "array",
          "description": "Hostnames matched by the HTTPRoute.",
          "default": [
            "scrutiny.local"
          ],
          "items": {
            "type": "string",
            "description": "Hostname matched by the HTTPRoute.",
            "default": "scrutiny.local"
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "CPU and memory requests and limits for the main application container.",
      "additionalProperties": true,
      "properties": {}
    },
    "probes": {
      "type": "object",
      "description": "Health probe configuration for the application workload.",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable this feature or generated resource.",
          "default": true
        }
      }
    }
  }
}
